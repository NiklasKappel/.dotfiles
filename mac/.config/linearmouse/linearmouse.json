{
  "$schema" : "https:\/\/schema.linearmouse.app\/0.10.0",
  "schemes" : [
    {
      "if" : {
        "device" : {
          "category" : "mouse",
        },
      },
      "buttons" : {
        "universalBackForward" : true,
      },
      "pointer" : {
        "acceleration" : 1,
        "disableAcceleration" : true,
        "speed" : 0,
      },
      "scrolling" : {
        "acceleration" : 1,
        "distance" : 3,
        "speed" : 0,
      },
    },
    {
      "if" : {
        "device" : {
          "category" : "trackpad",
        },
      },
      "pointer" : {
        "acceleration" : 1,
        "disableAcceleration" : false,
        "speed" : 1,
      },
      "scrolling" : {
        "acceleration" : 1,
        "speed" : 0,
        "distance" : "auto",
      },
    },
  ]
}
