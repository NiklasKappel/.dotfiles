config-file = ?auto/theme.ghostty

cursor-style-blink = false
font-size = 15
font-feature = -calt, -dlig, -liga
window-inherit-working-directory = false

keybind = alt+c=copy_to_clipboard
keybind = alt+v=paste_from_clipboard

keybind = alt+n=new_window

keybind = alt+t=new_tab
keybind = alt+shift+h=previous_tab
keybind = alt+shift+l=next_tab

keybind = alt+h=goto_split:left
keybind = alt+j=goto_split:down
keybind = alt+k=goto_split:up
keybind = alt+l=goto_split:right

keybind = alt+space>s>h=new_split:left
keybind = alt+space>s>j=new_split:down
keybind = alt+space>s>k=new_split:up
keybind = alt+space>s>l=new_split:right
keybind = alt+space>s>x=new_split:auto

# Fix Mac keybinds
key-remap = cmd=ctrl
keybind = cmd+d=unbind
keybind = cmd+shift+d=unbind
